# Environment Variables Template for Vercel Deployment
# Copy this file to .env and fill in your actual values

# API Secret Key (REQUIRED - generate strong random key, 32+ characters)
API_SECRET_KEY=your_min_32_char_secret_key_here

# MongoDB Connection Strings (REQUIRED for production)
# Set these specifically for your MongoDB Atlas clusters
MONGODB_URI_1=mongodb+srv://user:password@cluster0.example.mongodb.net/redirect_service?appName=Cluster0
MONGODB_URI_2=mongodb+srv://user2:password2@cluster1.example.mongodb.net/redirect_service?appName=Cluster1
MONGODB_URI_3=mongodb+srv://user3:password3@cluster2.example.mongodb.net/redirect_service?appName=Cluster2

# Cloudflare Turnstile (RECOMMENDED - FREE!)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAyyyyyyyyyyyy

# reCAPTCHA v3 (OPTIONAL)
RECAPTCHA_V3_SECRET=your_recaptcha_v3_secret_here

# Server Port (optional - defaults to 3000, not used on Vercel)
PORT=3000

# Environment settings (optional)
NODE_ENV=production
