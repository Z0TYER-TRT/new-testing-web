{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/store-session",
      "dest": "/api/store-session.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/process-session/(.*)",
      "dest": "/api/store-session.js?sessionId=$1",
      "methods": ["GET"]
    },
    {
      "src": "/access/(.*)",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
