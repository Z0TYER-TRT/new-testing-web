{
  "version": 2,
  "routes": [
    {
      "src": "/api/store-session",
      "dest": "/api/store-session",
      "methods": ["POST"]
    },
    {
      "src": "/api/process-session/(.*)",
      "dest": "/api/process-session/$1",
      "methods": ["GET"]
    },
    {
      "src": "/go/(.*)",
      "dest": "/go/$1",
      "methods": ["GET"]
    },
    {
      "src": "/link/(.*)",
      "dest": "/link/$1",
      "methods": ["GET"]
    },
    {
      "src": "/access/(.*)",
      "dest": "/access/$1",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/go/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/link/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/access/:path*",
      "destination": "/server.js"
    }
  ],
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
