{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10
      }
    }
  ],
  "routes": [
    {
      "src": "/api/store-session",
      "dest": "/server.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/process-session/(.*)",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/go/(.*)",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/access/(.*)",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/health",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/(.*\\.(css|js|ico|png|jpg|jpeg|svg|woff|woff2|ttf|eot))",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
